# Copy to .env and fill in. .env is gitignored.
# Never commit real values.

# Supabase — service_role key has admin privileges; treat like a password.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=

# YouTube Data API v3 key. Free tier: 10,000 units/day.
# Generate at https://console.cloud.google.com/apis/credentials (project: railprep-494208).
YOUTUBE_API_KEY=
